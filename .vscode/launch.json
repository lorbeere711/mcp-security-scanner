{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug MCP Scanner (insecure sample)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "scan",
        "./examples/insecure.json"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
